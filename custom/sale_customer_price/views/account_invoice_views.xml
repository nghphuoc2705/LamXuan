<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Thêm trường Chiết khấu % vào dòng hóa đơn (list) -->
    <record id="view_move_form_inherit_line_discount_pct_list" model="ir.ui.view">
        <field name="name">account.move.form.inherit.line.discount.pct.list</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='discount']" position="after">
                <field name="line_discount_pct" string="CK %" width="50px" optional="show"/>
            </xpath>
        </field>
    </record>
    <!-- Thêm trường Chiết khấu % vào form dòng hóa đơn (mobile form) -->
    <record id="view_move_form_inherit_line_discount_pct_form" model="ir.ui.view">
        <field name="name">account.move.form.inherit.line.discount.pct.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']/form//field[@name='discount']" position="after">
                <field name="line_discount_pct" string="Chiết khấu %"/>
            </xpath>
        </field>
    </record>
</odoo>
