<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_product_template_customer_inherit" model="ir.ui.view">
        <field name="name">product.template.customer.form.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='sale']" position="before">
                <group name="customer" string="Customer Prices">
                    <field name="customer_ids" 
                           context="{'default_product_tmpl_id': id, 'product_template_invisible_variant': True, 'list_view_ref':'sale_customer_price.product_customerinfo_tree_view2'}" 
                           nolabel="1" 
                           invisible="product_variant_count &gt; 1" 
                           readonly="product_variant_count &gt; 1"/>
                    <field name="variant_customer_ids" 
                           context="{'model': 'product.template', 'active_id': id, 'list_view_ref':'sale_customer_price.product_customerinfo_tree_view2'}" 
                           nolabel="1" 
                           invisible="product_variant_count &lt;= 1" 
                           readonly="product_variant_count &lt;= 1"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="view_product_product_customer_inherit" model="ir.ui.view">
        <field name="name">product.product.customer.form.inherit</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <field name="customer_ids" position="attributes">
                <attribute name="context">{'default_product_tmpl_id': product_tmpl_id, 'product_template_invisible_variant': True, 'list_view_ref':'sale_customer_price.product_customerinfo_tree_view2'}</attribute>
            </field>
            <field name="variant_customer_ids" position="attributes">
                <attribute name="context">{'model': 'product.product', 'active_id': id, 'list_view_ref':'sale_customer_price.product_customerinfo_tree_view2'}</attribute>
            </field>
        </field>
    </record>

</odoo>

