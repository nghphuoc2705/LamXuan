<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_order_form_inherit_partner_custom_view" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.partner.custom.view</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="domain">[('type_partner', '=', 'supplier')]</attribute>
            </xpath>
        </field>
    </record>
</odoo>