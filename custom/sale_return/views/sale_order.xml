<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_order_form_sale_return" model="ir.ui.view">
        <field name="name">sale.order.form.sale.return</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_draft']" position="attributes">
                <attribute name="string">Set to Draft</attribute>
            </xpath>
            <xpath expr="//button[@name='action_confirm'][2]" position="replace"/>
            <xpath expr="//button[@name='action_confirm']" position="replace">
                <button name="action_confirm" id="action_confirm" data-hotkey="q" string="Confirm" 
                    class="btn btn-primary" type="object" context="{'validate_analytic': True}" invisible="state not in ['sent'] or is_return == True"/>

                <button name="action_confirm" id="action_confirm"
                    string="Confirm Return" class="btn btn-primary" type="object"
                    invisible="state not in ['sent'] or is_return == False"/>
                <button name="action_return_sale_order" string="Tạo đơn trả hàng" type="object" 
                        class="btn-secondary" invisible="is_return == True or state not in ('sale')"/>

                <button name="action_confirm" data-hotkey="q" string="Confirm" type="object" context="{'validate_analytic': True}" invisible="state not in ['draft'] or is_return == True"/>

                <button name="action_confirm"
                    string="Confirm Return" type="object"
                    invisible="state not in ['draft'] or is_return == False"/>
            </xpath>
            <xpath expr="//field[@name='state']" position="attributes">
                <attribute name="invisible">is_return</attribute>
            </xpath>
            <xpath expr="//field[@name='state']" position="after">
                <field name="state_return" widget="statusbar" statusbar_visible="draft,sent,sale" invisible="is_return == False"/>
            </xpath>
            <xpath expr="//field[@name='name']" position="after">
                <field name="is_return" invisible="0"/>
                <field name="original_sale_order_id" invisible="is_return == False" readonly="1"/>
            </xpath>
            <!-- Add Return Orders button in button box -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_return_orders" type="object"
                        class="oe_stat_button" icon="fa-undo"
                        invisible="return_count == 0 or is_return == True">
                    <field name="return_count" widget="statinfo" string="Trả hàng"/>
                </button>
            </xpath>
            <xpath expr="//list//field[@name='product_uom_qty']" position="before">
                <field name="location_id" column_invisible="parent.is_return == False"/>
            </xpath>
            <xpath expr="//list//field[@name='product_uom_qty']" position="attributes">
                <attribute name="string">Quantity</attribute>
            </xpath>
            <xpath expr="//list//field[@name='qty_delivered']" position="before">
                <field name="qty_change" column_invisible="1"/>
            </xpath>
            <xpath expr="//list//field[@name='qty_delivered']" position="attributes">
                <attribute name="column_invisible">parent.state not in ['sale', 'done'] or parent.is_return</attribute>
            </xpath>
            <xpath expr="//list//field[@name='qty_delivered']" position="after">
                <field name="qty_returned" column_invisible="parent.state not in ['sale', 'done'] or parent.is_return == False"/>
                <field name="qty_changed" column_invisible="1"/>
            </xpath>
            <xpath expr="//list//field[@name='qty_invoiced']" position="attributes">
                <attribute name="column_invisible">parent.state not in ['sale', 'done'] or parent.is_return</attribute>
            </xpath>
            <xpath expr="//list//field[@name='qty_invoiced']" position="after">
                <field name="qty_returned_invoiced" column_invisible="parent.state not in ['sale', 'done'] or parent.is_return == False"/>
            </xpath>
         </field>
    </record>
    <record id="view_sales_order_filter" model="ir.ui.view">
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_sales_order_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="before">
                <filter name="no_returns_domain" string="Sale Order and Quotations" domain="[('is_return', '=', False)]"/>
                <filter name="returns_domain" string="Returns" domain="[('is_return', '=', True)]"/>
                <filter name="returns_group" string="Is return" domain="[]" context="{'group_by': 'is_return'}"/>
            </xpath>
        </field>
    </record>
    <record id="sale.action_orders" model="ir.actions.act_window">
        <field name="domain">[('is_return', '=', False),('state', 'not in', ('draft', 'sent', 'cancel'))]</field>
    </record>
    <record id="sale.action_quotations_with_onboarding" model="ir.actions.act_window">
        <field name="domain">[('is_return', '=', False)]</field>
    </record>
    <record id="sale_order_return_action" model="ir.actions.act_window">
        <field name="name">Sale return</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,form,calendar,graph,pivot,kanban</field>
        <field name="domain">[('is_return', '=', True)]</field>
        <field name="context">{'search_default_returns_domain': 1, 'default_is_return': 'True'}</field>
        <field name="search_view_id" ref="sale.view_sales_order_filter"/>
    </record>

    <record id="action_update_effective_date_order_return" model="ir.actions.server">
        <field name="name">Update Effective Date Order Return</field>
        <field name="type">ir.actions.server</field>
        <field name="state">code</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="code">
            records._compute_effective_date()
        </field>
    </record>

    <menuitem
        id="sale_return_menu"
        parent="sale.sale_order_menu"
        action="sale_order_return_action"
        groups="sales_team.group_sale_salesman"
        sequence="20"/>
</odoo>
