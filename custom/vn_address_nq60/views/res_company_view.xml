<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model='ir.ui.view' id='view_company_bizapps_form'>
        <field name='name'>res.company.form</field>
        <field name='model'>res.company</field>
        <field name="inherit_id" ref='biz_vn_address.view_company_bizapps_form'></field>
        <field name='arch' type='xml'>
            <field name="district_id" position="attributes" >
                <attribute name='invisible'>1</attribute>
                <attribute name='required'>0</attribute>
            </field>
            <field name="wards_id" position="attributes" >
                <attribute name='domain'>[('state_id', '=', state_id)]</attribute>
                <attribute name="context">{'filter_is_new': True}</attribute>
            </field>
        </field>
    </record>
</odoo>