<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model='ir.ui.view' id='view_partner_form_client'>
        <field name='name'>res.partner.form</field>
        <field name='model'>res.partner</field>
        <field name="inherit_id" ref='biz_vn_address.view_partner_form_client'></field>
        <field name='arch' type='xml'>
            <field name="district_id" position="attributes" >
                <attribute name='invisible'>0</attribute>
                <attribute name='required'>0</attribute>
            </field>
            <field name="wards_id" position="attributes" >
                <attribute name='domain'>[('state_id', '=', state_id)]</attribute>
                <attribute name="context">{'filter_is_new': True}</attribute>
            </field>
            <xpath expr="//field[@name='child_ids']/form/sheet/group/group/div/div/field[@name='district_id']" position="attributes">
                <attribute name='invisible'>1</attribute>
                <attribute name='required'>0</attribute>
            </xpath>
            <xpath expr="//field[@name='child_ids']/form/sheet/group/group/div/div/field[@name='wards_id']" position="attributes">
                <attribute name='domain'>[('state_id', '=', state_id)]</attribute>
            </xpath>
        </field>
    </record>
</odoo>