<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="web_switch_company_visibility.SwitchCompanyMenu"
       t-inherit="web.SwitchCompanyMenu"
       t-inherit-mode="extension">
        <xpath expr="//div[contains(@class, 'o_switch_company_menu')]" position="attributes">
            <attribute name="t-if">true</attribute>
        </xpath>
        <xpath expr="//Dropdown" position="attributes">
            <attribute name="disabled">isSingleCompany or !hasMultiCompanyGroup</attribute>
        </xpath>
    </t>
</templates>
