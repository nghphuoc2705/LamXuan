<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_company_bizapps_form" model="ir.ui.view">
        <field name="name">res.company.form.client</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form" />
        <field name="arch" type="xml">
            <div class="o_address_format" position="replace">
                <div class="o_address_format">
                    <field name="parent_id"  invisible="1"/>
                    <field name="street" placeholder="Street..." class="o_address_street" readonly="parent_id != False"/>
                    <field name="country_id" placeholder="Country" style="width: 19%" options="{&quot;no_open&quot;: True, &quot;no_create&quot;: True}" readonly="parent_id != False"/>
                    <field name="state_id" style="width: 27%" placeholder="Province/City" options="{&quot;no_open&quot;: True}" domain="[('country_id', '=', country_id)]" readonly="parent_id != False" context="{'country_id': country_id, 'zip': zip}" />
                    <field name="district_id" placeholder="District" style="width: 27%" domain="[('state_id', '=', state_id)]" readonly="parent_id != False"/>
                    <field name="wards_id" placeholder="Wards" style="width: 27%" domain="[('district_id', '=', district_id)]" readonly="parent_id != False"/>
                    <field name="city" invisible="1" />
                    <field name="zip" invisible="1" />
                    <field name="street2" invisible="1" />
                </div>
            </div>
        </field>
    </record>
</odoo>