<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="report_saleorder_document_inherit" inherit_id="sale.report_saleorder_document">
        <xpath expr="//table[hasclass('o_main_table')]/thead/tr/th" position="after">
            <th name="th_image" class="text-start">Image</th>
        </xpath>
        <xpath expr="//td[@name='td_quantity']" position="before">
            <td>
                <t t-if="line.product_id.image_1920">
                    <img t-att-src="image_data_uri(line.product_id.image_1920)" width="100" height="100"/>
                </t>
                <t t-else="">
                    <td>&amp;nbsp;</td>
                </t>
            </td>
        </xpath>
    </template>
</odoo>
