<odoo>
    <record id="view_product_form_inherit" model="ir.ui.view">
        <field name="name">product.template.form.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='image_1920']" position="attributes">
                <attribute name="style">float: left;</attribute>
                <attribute name="class" remove="oe_avatar" add="m-3" separator=" " />
            </xpath>

            <xpath expr="//div[@name='options']" position="after">
                <field name="image_1" widget="image" alt="Product" class="ms-auto m-2" options="{'size': [100, 100]}"/>
                <field name="image_2" widget="image" alt="Product" class="ms-auto m-2" options="{'size': [100, 100]}"/>
                <field name="image_3" widget="image" alt="Product" class="ms-auto m-2" options="{'size': [100, 100]}"/>
                <field name="image_4" widget="image" alt="Product" class="ms-auto m-2" options="{'size': [100, 100]}"/>
                <field name="image_5" widget="image" alt="Product" class="ms-auto m-2" options="{'size': [100, 100]}"/>
            </xpath>

            <xpath expr="//group[@name='internal_notes']" position="before">
                <group>
                    <group string="Product Information">
                        <field name="brand_id" widget="many2one"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
