<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<template id = "stock_report_delivery" inherit_id = "stock.report_delivery_document">
		<xpath expr="//table[@name='stock_move_table']/thead/tr/th[1]" position="after">
			<th>Image</th>
		</xpath>
		<xpath expr="//table[@name='stock_move_table']/tbody/tr[@t-foreach='lines']/td[1]" position="after">
		<td>
			<img t-if="move.image_128" t-att-src="image_data_uri(move.image_128)" style="width: 90%"/>
		</td>
		</xpath>

		<xpath expr="//table[@name='stock_move_line_table']/thead/tr/th[@name='th_sml_product']" position="after">
			<th>Image</th>
		</xpath>

		<xpath expr="//table[1]/thead/tr/th[@name='th_sm_product']" position="before">
			<th>Sr. No</th>
		</xpath>
		<xpath expr="//table[1]/tbody/tr/td[1]" position="before">
		<td style ="text-align:center;">
			<span t-field="move.sr_number"/>
		</td>
		</xpath>

		<xpath expr="//table[@name='stock_move_line_table']/thead/tr/th[@name='th_sml_product']" position="before">
			<th>Sr. No</th>
		</xpath>

	</template>

	<template id = "stock_report_inherit" inherit_id = "stock.report_picking">
		<xpath expr="//table[1]/thead/tr/th[@name='th_product']" position="before">
			<th>Sr. No</th>
		</xpath>
		<xpath expr="//table[1]/tbody/tr/td[1]" position="before">
			<!-- <t> -->
				<td style ="text-align:center;">
					<span t-field="ml.move_id.sr_number"/>
				</td>
			<!-- </t> -->
		</xpath>
		<xpath expr="//table[1]/thead/tr/th[@name='th_product']" position="after">
			<th><strong>Image</strong></th>
		</xpath>
		<xpath expr="//table[1]/tbody/tr/td[2]" position="after">
			<td><img t-if="ml.product_id.image_128"
				t-att-src="image_data_uri(ml.product_id.image_128)" style="width: 90%"/></td>
		</xpath>
	</template>

	<template id = "stock_moveline_report_delivery" inherit_id = "stock.stock_report_delivery_has_serial_move_line">
		<xpath expr="//td[1]" position="after">
        <t>
            <td>
            	<img t-if="move_line.move_id.image_128"
            		t-att-src="image_data_uri(move_line.move_id.image_128)" style="width: 90%"/>
			</td>
        </t>
		</xpath>
		<xpath expr="//td[1]" position="before">
        <t>
            <td>
                <span t-field="move_line.move_id.sr_number"/>
			</td>
        </t>
		</xpath>
		
	</template>

	<template id = "stock_aggregated_moveline_report_delivery" inherit_id = "stock.stock_report_delivery_aggregated_move_lines">
		<xpath expr="//tr/td[1]" position="after">
            <td>
            	<img t-if="aggregated_lines[line]['product']['image_1920']"
            		t-att-src="image_data_uri(aggregated_lines[line]['product']['image_1920'])" style="width: 90%"/>
			</td>
		</xpath>
		<xpath expr="//tr/td[1]" position="before">
			<t>
            <td style ="text-align:center;">
				<span t-esc="aggregated_lines[line]['sr_number']"/>
			</td>
			</t>
		</xpath>
	</template>
</odoo>