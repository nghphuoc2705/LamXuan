<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="cloth_type_form_view" model="ir.ui.view">
        <field name="name">cloth.type.form</field>
        <field name="model">cloth.type</field>
        <field name="arch" type="xml">
            <form string="Cloth Type" class="o_sale_order">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="gender"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="cloth_measurment" string="Measurments">
                            <field name="measurement_ids">
                                <list editable="bottom" string="Cloat Measurment">
                                    <field name="name"/>
                                    <field name="uom_id"/>
                                    <field name="sequence_no"/>
                                </list>
                                <form>
                                    <group>
                                        <group>
                                            <field name="name"/>
                                            <field name="uom_id"/>
                                        </group>
                                        <group>
                                            <field name="sequence_no"/>
                                        </group>
                                    </group>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="cloth_type_list_view" model="ir.ui.view">
        <field name="name">cloth.type.list</field>
        <field name="model">cloth.type</field>
        <field name="arch" type="xml">
            <list string="Cloth Type">
                <field name="name"/>
                <field name="gender"/>
            </list>
        </field>
    </record>

    <record id="action_cloth_type" model="ir.actions.act_window">
        <field name="name">Cloth Types</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">cloth.type</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
            </p>
        </field>
    </record>

    <record id="cloth_image_form_view" model="ir.ui.view">
        <field name="name">cloth.image.form</field>
        <field name="model">cloth.image</field>
        <field name="arch" type="xml">
            <form string="Cloth image" class="o_sale_order">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="note"/>
                        </group>
                        <group>
                            <field name="image" widget="image" style="height: 90px;
                                                                         width: 90px;"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="cloth_image_list_view" model="ir.ui.view">
        <field name="name">cloth.image.list</field>
        <field name="model">cloth.image</field>
        <field name="arch" type="xml">
            <list string="Cloth image">
                <field name="name"/>
                <field name="image" widget="image"/>
                 <field name="note"/>
            </list>
        </field>
    </record>
    <record id="action_cloth_image" model="ir.actions.act_window">
        <field name="name">Cloth Images</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">cloth.image</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
            </p>
        </field>
    </record>
</odoo>